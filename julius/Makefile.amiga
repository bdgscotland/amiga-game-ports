# Build object files into flat obj/ directory to avoid name collisions
# (e.g. src/building/figure.c vs src/map/figure.c)
OBJS = $(patsubst %.c,obj/%.o,$(subst /,_,$(SRCS_ALL)))

all: $(OUT)

$(OUT): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $(OBJS) $(LDFLAGS)

obj:
	mkdir -p obj

# Pattern: flatten source path to obj/path_to_file.o
# We generate explicit rules via a template

define COMPILE_RULE
obj/$(subst /,_,$(1:.c=.o)): $(1) | obj
	$$(CC) $$(CFLAGS) -c -o $$@ $$<
endef

$(foreach src,$(SRCS_ALL),$(eval $(call COMPILE_RULE,$(src))))

clean:
	rm -rf obj $(OUT)

# Count sources for verification
count:
	@echo "Source files: $(words $(SRCS_ALL))"

.PHONY: all clean count
