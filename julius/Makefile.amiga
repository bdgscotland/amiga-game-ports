# Julius (Caesar III) -- AmigaOS 3.x cross-compile via Docker
#
# Usage:
#   make -f Makefile.amiga           # build julius binary
#   make -f Makefile.amiga clean     # clean
#
# Requires: bebbo/amiga-gcc Docker image, libSDL2.a built in ../../

SDL2_ROOT = ../..
CC = m68k-amigaos-gcc

# C math -> SDL software implementations (avoids ROM IEEE library crashes)
MATH_REDIRECTS = \
    -Dsinf=SDL_sinf -Dcosf=SDL_cosf -Dfloorf=SDL_floorf \
    -Dfabsf=SDL_fabsf -Dsqrtf=SDL_sqrtf -Dfmodf=SDL_fmodf \
    -Datan2f=SDL_atan2f -Dpowf=SDL_powf -Dceilf=SDL_ceilf \
    -Dsin=SDL_sin -Dcos=SDL_cos -Dfloor=SDL_floor \
    -Dfabs=SDL_fabs -Dsqrt=SDL_sqrt -Datan2=SDL_atan2 \
    -Dpow=SDL_pow -Dceil=SDL_ceil -Dlog=SDL_log

CFLAGS = -std=gnu99 -O0 -m68030 -noixemul \
         -Wall -Wno-unused-parameter -Wno-missing-field-initializers \
         -Wno-sign-compare \
         -I$(SDL2_ROOT)/include -I$(SDL2_ROOT)/src \
         -Isrc -Iext \
         -D__AMIGAOS3__ -D__AMIGA__ \
         -DPLATFORM_USE_SOFTWARE_CURSOR \
         $(MATH_REDIRECTS)

LDFLAGS = -noixemul -L$(SDL2_ROOT) -lSDL2 -lm

OUT = julius

# --- Source Files ---
# Generated from CMakeLists.txt, excluding:
#   - ext/tinyfiledialogs/ (replaced by amiga/tinyfd_stub.c)
#   - ext/png/ + src/graphics/screenshot.c (replaced by amiga/screenshot_stub.c)
#   - src/platform/sound_device.c (replaced by amiga/sound_stub.c -- no SDL_mixer)
#   - platform-specific: vita, switch, android, ios, emscripten

SRCS_AMIGA_STUBS = \
	amiga/tinyfd_stub.c \
	amiga/screenshot_stub.c \
	amiga/sound_stub.c

